# Smart Grid Digital Twin — Backend Environment Variables
# Copy this file to .env and fill in your values

# Optional: Anthropic API key for AI-powered explanations
# If not provided, the built-in knowledge base is used as fallback
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port (default: 5000)
PORT=5000

# Environment
NODE_ENV=development
